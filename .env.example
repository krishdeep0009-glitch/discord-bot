# ──────────────────────────────────────────────
# Blined Cloud VPS Manager — Environment Config
# Copy this file to .env and fill in the values
# ──────────────────────────────────────────────

# Your Discord bot token (from https://discord.com/developers/applications)
DISCORD_TOKEN=your_discord_bot_token_here

# The numeric ID of the Discord role that grants admin access
# Right-click the role in Discord → Copy ID (requires Developer Mode)
# Set to 0 to disable role-based admin
ADMIN_ROLE_ID=123456789012345678

# Comma-separated Discord USER IDs that have full admin access
# These users can use admin commands regardless of their roles
# Right-click a user in Discord → Copy ID (requires Developer Mode)
# Example with multiple admins: 111111111111111111,222222222222222222
ADMIN_USER_IDS=your_discord_user_id_here
