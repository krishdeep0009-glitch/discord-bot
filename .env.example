# ──────────────────────────────────────────────
# Blined Cloud VPS Manager — Environment Config
# Copy this file to .env and fill in the values
# ──────────────────────────────────────────────

# Your Discord bot token (from https://discord.com/developers/applications)
DISCORD_TOKEN=your_discord_bot_token_here

# The numeric ID of the Discord role that grants admin access
# Right-click the role in Discord → Copy ID (requires Developer Mode)
ADMIN_ROLE_ID=123456789012345678

# Starting host port for SSH — each VPS gets the next port (2200, 2201, 2202 ...)
# Make sure your VPS firewall allows this port range
SSH_PORT_START=2200
